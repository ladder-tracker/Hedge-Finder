<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bet Math Toolkit MVP</title>
  <style>
    :root {
      --bg: #0b1020;
      --bg2: #10182e;
      --card: #151f3b;
      --card2: #1b2748;
      --line: rgba(255,255,255,0.08);
      --text: #eef3ff;
      --muted: #9fb0d0;
      --blue: #5fa8ff;
      --green: #1fd37a;
      --red: #ff5d73;
      --yellow: #ffcc66;
      --shadow: 0 12px 28px rgba(0,0,0,0.25);
      --radius: 18px;
    }

    * { box-sizing: border-box; }
    html, body {
      margin: 0;
      padding: 0;
      background: linear-gradient(180deg, #08101f 0%, var(--bg) 100%);
      color: var(--text);
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    body { min-height: 100vh; }
    button, input, select { font: inherit; }

    .shell {
      width: 100%;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 14px 92px;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      background: rgba(8,16,31,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line);
    }

    .topbar-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 12px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .brand h1 {
      margin: 0;
      font-size: 1rem;
      line-height: 1.1;
      letter-spacing: -0.02em;
    }

    .brand p {
      margin: 3px 0 0;
      font-size: 0.82rem;
      color: var(--muted);
    }

    .btn, .btn-ghost, .btn-soft {
      border: 0;
      border-radius: 14px;
      cursor: pointer;
      min-height: 46px;
      padding: 12px 14px;
      transition: 0.16s ease;
      color: var(--text);
    }
    .btn:hover, .btn-ghost:hover, .btn-soft:hover { transform: translateY(-1px); }

    .btn {
      background: linear-gradient(180deg, var(--blue), #3b82f6);
      font-weight: 800;
    }

    .btn-soft {
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line);
      font-weight: 700;
    }

    .btn-ghost {
      background: transparent;
      border: 1px dashed var(--line);
      color: var(--muted);
      font-weight: 700;
    }

    .menu-btn {
      width: 44px;
      min-width: 44px;
      height: 44px;
      padding: 0;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin: 14px 0;
    }

    .stat {
      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 12px;
      box-shadow: var(--shadow);
    }

    .stat .label {
      color: var(--muted);
      font-size: 0.76rem;
      margin-bottom: 5px;
    }

    .stat .value {
      font-size: 1.08rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .green { color: var(--green); }
    .red { color: var(--red); }
    .yellow { color: var(--yellow); }

    .tabs {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      scrollbar-width: none;
      padding-bottom: 3px;
      margin-bottom: 14px;
    }
    .tabs::-webkit-scrollbar { display: none; }

    .tab {
      white-space: nowrap;
      border: 1px solid var(--line);
      background: var(--bg2);
      color: var(--text);
      padding: 10px 14px;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 700;
    }

    .tab.active {
      background: linear-gradient(180deg, var(--blue), #3b82f6);
      border-color: transparent;
    }

    .panel { display: none; }
    .panel.active { display: block; }

    .grid2 {
      display: grid;
      gap: 14px;
    }

    .card {
      background: linear-gradient(180deg, rgba(28,38,70,0.95), rgba(18,26,48,0.98));
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 16px;
      box-shadow: var(--shadow);
      margin-bottom: 14px;
    }

    .head {
      margin-bottom: 14px;
    }

    .head h2, .head h3 {
      margin: 0;
      font-size: 1rem;
      letter-spacing: -0.02em;
    }

    .head p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.4;
    }

    .fields, .results-grid {
      display: grid;
      gap: 10px;
    }

    .fields.two, .results-grid.two {
      grid-template-columns: 1fr 1fr;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .field label {
      font-size: 0.82rem;
      color: var(--muted);
      font-weight: 600;
    }

    .field input, .field select {
      width: 100%;
      min-height: 48px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.03);
      color: var(--text);
      padding: 12px 14px;
      outline: none;
    }

    .field input::placeholder { color: #7f92b9; }

    .row-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 14px;
    }

    .leg-row {
      display: grid;
      grid-template-columns: 1fr 86px 96px;
      gap: 10px;
      margin-bottom: 10px;
    }

    .toggle {
      display: flex;
      border: 1px solid var(--line);
      border-radius: 14px;
      overflow: hidden;
      background: rgba(255,255,255,0.03);
      min-height: 48px;
    }

    .toggle button {
      flex: 1;
      border: 0;
      background: transparent;
      color: var(--text);
      cursor: pointer;
      font-weight: 800;
    }

    .toggle button.active {
      background: var(--blue);
      color: white;
    }

    .metric {
      background: var(--card2);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 14px;
    }

    .metric .k {
      color: var(--muted);
      font-size: 0.76rem;
      margin-bottom: 6px;
    }

    .metric .v {
      font-size: 1.12rem;
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.02em;
    }

    .decision {
      margin-top: 12px;
      border-radius: 16px;
      padding: 14px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.03);
    }

    .decision.good {
      border-color: rgba(31,211,122,0.35);
      background: rgba(31,211,122,0.08);
    }

    .decision.bad {
      border-color: rgba(255,93,115,0.35);
      background: rgba(255,93,115,0.08);
    }

    .decision.warn {
      border-color: rgba(255,204,102,0.35);
      background: rgba(255,204,102,0.08);
    }

    .decision .t {
      font-weight: 800;
      margin-bottom: 6px;
      font-size: 0.92rem;
    }

    .decision .c {
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.42;
    }

    .history {
      display: grid;
      gap: 10px;
    }

    .history-item {
      background: var(--card2);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 12px;
    }

    .history-item strong {
      display: block;
      margin-bottom: 4px;
    }

    .history-item span {
      color: var(--muted);
      font-size: 0.84rem;
    }

    .bottom-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 25;
      background: rgba(8,16,31,0.94);
      backdrop-filter: blur(12px);
      border-top: 1px solid var(--line);
      padding: 8px 12px calc(8px + env(safe-area-inset-bottom));
    }

    .bottom-nav-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }

    .nav-btn {
      border: 0;
      border-radius: 14px;
      background: transparent;
      color: var(--muted);
      padding: 10px 8px;
      cursor: pointer;
      font-size: 0.78rem;
      font-weight: 700;
    }

    .nav-btn.active {
      color: var(--text);
      background: rgba(255,255,255,0.05);
    }

    .modal-wrap {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      display: none;
      align-items: flex-end;
      z-index: 30;
    }

    .modal-wrap.open { display: flex; }

    .modal {
      width: 100%;
      max-width: 1100px;
      margin: 0 auto;
      background: #111a31;
      border-top-left-radius: 22px;
      border-top-right-radius: 22px;
      border: 1px solid var(--line);
      padding: 18px 16px 24px;
    }

    .modal h3 {
      margin: 0 0 6px;
    }

    .modal p {
      margin: 0 0 14px;
      color: var(--muted);
      font-size: 0.9rem;
    }

    @media (min-width: 760px) {
      .stats {
        grid-template-columns: repeat(4, 1fr);
      }
      .grid2 {
        grid-template-columns: 1.05fr 0.95fr;
      }
      .bottom-nav {
        display: none;
      }
      .shell {
        padding-bottom: 32px;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <h1>Bet Math Toolkit</h1>
        <p>Manual-input MVP</p>
      </div>
      <button class="btn-soft menu-btn" id="openMenu">⋯</button>
    </div>
  </header>

  <main class="shell">
    <section class="stats">
      <div class="stat">
        <div class="label">Bankroll</div>
        <div class="value" id="bankrollStat">$250.00</div>
      </div>
      <div class="stat">
        <div class="label">Total P/L</div>
        <div class="value green" id="plStat">+$48.25</div>
      </div>
      <div class="stat">
        <div class="label">Goal</div>
        <div class="value" id="goalStat">$1,000.00</div>
      </div>
      <div class="stat">
        <div class="label">Run Status</div>
        <div class="value yellow" id="runStatus">Active</div>
      </div>
    </section>

    <nav class="tabs" id="tabs">
      <button class="tab active" data-panel="parlayPanel">Parlay Analyzer</button>
      <button class="tab" data-panel="cashoutPanel">Cashout Tool</button>
      <button class="tab" data-panel="hedgePanel">Hedge Calculator</button>
      <button class="tab" data-panel="ladderPanel">Ladder Tracker</button>
    </nav>

    <section class="panel active" id="parlayPanel">
      <div class="grid2">
        <div>
          <div class="card">
            <div class="head">
              <h2>Parlay Analyzer</h2>
              <p>Enter the legs manually.</p>
            </div>

            <div class="fields two">
              <div class="field">
                <label for="parlayStake">Stake</label>
                <input id="parlayStake" type="number" min="0" step="0.01" placeholder="25" />
              </div>
              <div class="field">
                <label for="parlayLegCount">Number of Legs</label>
                <select id="parlayLegCount">
                  <option value="2">2</option>
                  <option value="3" selected>3</option>
                  <option value="4">4</option>
                  <option value="5">5</option>
                  <option value="6">6</option>
                </select>
              </div>
            </div>

            <div id="parlayLegs" style="margin-top: 12px;"></div>

            <div class="row-actions">
              <button class="btn" id="analyzeParlayBtn">Analyze Parlay</button>
              <button class="btn-soft" id="resetParlayBtn">Reset</button>
            </div>
          </div>
        </div>

        <div>
          <div class="card">
            <div class="head">
              <h3>Results</h3>
            </div>

            <div class="results-grid two">
              <div class="metric"><div class="k">Sportsbook Parlay Odds</div><div class="v" id="parlaySportsbookOdds">+0</div></div>
              <div class="metric"><div class="k">Modeled True Odds</div><div class="v" id="parlayTrueOdds">+0</div></div>
              <div class="metric"><div class="k">Implied Probability</div><div class="v" id="parlayImpliedProb">0.00%</div></div>
              <div class="metric"><div class="k">Modeled Probability</div><div class="v" id="parlayTrueProb">0.00%</div></div>
              <div class="metric"><div class="k">Potential Payout</div><div class="v" id="parlayPayout">$0.00</div></div>
              <div class="metric"><div class="k">Expected Value</div><div class="v" id="parlayEv">$0.00</div></div>
            </div>

            <div class="decision bad" id="parlayDecision">
              <div class="t" id="parlayDecisionTitle">Waiting for input</div>
              <div class="c" id="parlayDecisionCopy">Add odds and analyze.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="panel" id="cashoutPanel">
      <div class="grid2">
        <div>
          <div class="card">
            <div class="head">
              <h2>Cashout Tool</h2>
            </div>

            <div class="fields two">
              <div class="field"><label>Original Stake</label><input id="cashStake" type="number" /></div>
              <div class="field"><label>Potential Payout</label><input id="cashPayout" type="number" /></div>
              <div class="field"><label>Cashout Offer</label><input id="cashOffer" type="number" /></div>
              <div class="field"><label>Remaining Odds</label><input id="cashOdds" type="text" /></div>
            </div>

            <div class="row-actions">
              <button class="btn" id="analyzeCashoutBtn">Analyze Cashout</button>
              <button class="btn-soft" id="resetCashoutBtn">Reset</button>
            </div>
          </div>
        </div>

        <div>
          <div class="card">
            <div class="results-grid two">
              <div class="metric"><div class="k">Fair Value</div><div class="v" id="cashFairValue">$0.00</div></div>
              <div class="metric"><div class="k">Offer</div><div class="v" id="cashOfferOut">$0.00</div></div>
              <div class="metric"><div class="k">Gap</div><div class="v" id="cashGap">0%</div></div>
              <div class="metric"><div class="k">EV vs Cash</div><div class="v" id="cashHoldEv">$0.00</div></div>
            </div>

            <div class="decision bad" id="cashDecision">
              <div class="t" id="cashDecisionTitle">Waiting</div>
              <div class="c" id="cashDecisionCopy">Enter values</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="panel" id="hedgePanel">
      <div class="grid2">
        <div>
          <div class="card">
            <div class="fields two">
              <div class="field"><label>Stake</label><input id="hedgeStake" type="number" /></div>
              <div class="field"><label>Payout</label><input id="hedgePayout" type="number" /></div>
              <div class="field"><label>Odds</label><input id="hedgeOdds" type="text" /></div>
              <div class="field"><label>Target</label><input id="hedgeTarget" type="number" /></div>
            </div>

            <div class="row-actions">
              <button class="btn" id="calcHedgeBtn">Calculate</button>
              <button class="btn-soft" id="resetHedgeBtn">Reset</button>
            </div>
          </div>
        </div>

        <div>
          <div class="card">
            <div class="results-grid two">
              <div class="metric"><div class="k">Equal Hedge</div><div class="v" id="hedgeEqualAmt">$0.00</div></div>
              <div class="metric"><div class="k">Win Profit</div><div class="v" id="hedgeEqualWin">$0.00</div></div>
              <div class="metric"><div class="k">Lose Profit</div><div class="v" id="hedgeEqualLose">$0.00</div></div>
            </div>

            <div class="decision warn" id="hedgeDecision">
              <div class="t" id="hedgeDecisionTitle">Waiting</div>
              <div class="c" id="hedgeDecisionCopy">Enter inputs</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="panel" id="ladderPanel"></section>
  </main>

  <script>
    const $ = id => document.getElementById(id);

    function parseOdds(v) {
      if (!v) return null;
      const cleaned = String(v).replace(/,/g,'').replace(/−/g,'-').trim();
      const n = Number(cleaned);
      return Number.isFinite(n) && n !== 0 ? n : null;
    }

    function americanToDecimal(o){return o>0?1+o/100:1+100/Math.abs(o)}
    function americanToProb(o){return o>0?100/(o+100):Math.abs(o)/(Math.abs(o)+100)}
    function probToAmerican(p){if(!(p>0&&p<1))return 'N/A';return p<.5?`+${Math.round(((1-p)/p)*100)}`:`${Math.round(-(p/(1-p))*100)}`}

    function fmtMoney(n){return new Intl.NumberFormat('en-US',{style:'currency',currency:'USD'}).format(n||0)}

    function renderParlayLegs(n){
      const w=$('parlayLegs');w.innerHTML='';
      for(let i=0;i<n;i++){
        const d=document.createElement('div');
        d.className='leg-row';
        d.innerHTML=`<div class="field"><input class="leg-odds" placeholder="+120"/></div><div></div><div class="field"><input class="leg-prob"/></div>`;
        w.appendChild(d);
      }
    }

    function analyzeParlay(){
      const stake=Number($('parlayStake').value||0);
      const odds=[...document.querySelectorAll('.leg-odds')];
      const probs=[...document.querySelectorAll('.leg-prob')];
      let imp=1,trueP=1,dec=1;

      odds.forEach((o,i)=>{
        const val=parseOdds(o.value);
        if(!val)return;
        const p=americanToProb(val);
        imp*=p;
        dec*=americanToDecimal(val);
        const user=Number(probs[i].value);
        trueP*=user>0&&user<100?user/100:p;
      });

      const payout=stake*dec;
      const ev=(trueP*(payout-stake))-((1-trueP)*stake);

      $('parlaySportsbookOdds').textContent=probToAmerican(imp);
      $('parlayTrueOdds').textContent=probToAmerican(trueP);
      $('parlayImpliedProb').textContent=(imp*100).toFixed(2)+'%';
      $('parlayTrueProb').textContent=(trueP*100).toFixed(2)+'%';
      $('parlayPayout').textContent=fmtMoney(payout);
      $('parlayEv').textContent=fmtMoney(ev);
    }

    function analyzeCashout(){
      const payout=Number($('cashPayout').value||0);
      const offer=Number($('cashOffer').value||0);
      const odds=parseOdds($('cashOdds').value);
      if(!payout||!odds)return;
      const p=americanToProb(odds);
      const fair=payout*p;
      const gap=((offer-fair)/fair)*100;

      $('cashFairValue').textContent=fmtMoney(fair);
      $('cashOfferOut').textContent=fmtMoney(offer);
      $('cashGap').textContent=gap.toFixed(1)+'%';
      $('cashHoldEv').textContent=fmtMoney(fair-offer);

      const box=$('cashDecision');
      box.className='decision';
      if(gap>3){box.classList.add('good');$('cashDecisionTitle').textContent='Above fair';}
      else if(gap<-3){box.classList.add('bad');$('cashDecisionTitle').textContent='Below fair';}
      else{box.classList.add('warn');$('cashDecisionTitle').textContent='Near fair';}
    }

    function calculateHedge(){
      const stake=Number($('hedgeStake').value||0);
      const payout=Number($('hedgePayout').value||0);
      const odds=parseOdds($('hedgeOdds').value);
      if(!payout||!odds)return;
      const dec=americanToDecimal(odds);
      const amt=payout/dec;
      $('hedgeEqualAmt').textContent=fmtMoney(amt);
      $('hedgeEqualWin').textContent=fmtMoney(payout-amt-stake);
      $('hedgeEqualLose').textContent=fmtMoney((amt*(dec-1))-stake);
    }

    $('parlayLegCount').addEventListener('change',e=>renderParlayLegs(Number(e.target.value)));
    $('analyzeParlayBtn').addEventListener('click',analyzeParlay);
    $('analyzeCashoutBtn').addEventListener('click',analyzeCashout);
    $('calcHedgeBtn').addEventListener('click',calculateHedge);

    renderParlayLegs(3);
  </script>
</body>
</html>
